# Copy to .env and fill in. All values have sane defaults except Supabase.

# Port the Socket.io / HTTP server listens on.
PORT=4000

# Allowed CORS origin for the Next.js frontend (use the deployed URL in prod).
CORS_ORIGIN=http://localhost:3000

# How long (ms) to hold a disconnected player's seat before removing them.
RECONNECT_GRACE_MS=60000

# Pause (ms) on the round-result screen before dealing the next round.
ROUND_END_DELAY_MS=4000

# Supabase — required for real auth (verifying user JWTs + username lookup) and
# for persisting completed matches to the `matches` table. Leave blank to run
# with DEV_AUTH only and the in-memory history store.
# The service-role key is used server-side to verify sessions and read profiles.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Dev-only auth bypass. When 1/true, the server accepts `dev:<username>` socket
# tokens so you can play locally without Google OAuth. MUST be unset in prod.
DEV_AUTH=1
