# Copy to .env and fill in. All values have sane defaults except Supabase.

# Port the Socket.io / HTTP server listens on.
PORT=4000

# Allowed CORS origin for the Next.js frontend (use the deployed URL in prod).
CORS_ORIGIN=http://localhost:3000

# How long (ms) to hold a disconnected player's seat before removing them.
RECONNECT_GRACE_MS=60000

# Pause (ms) on the round-result screen before dealing the next round.
ROUND_END_DELAY_MS=4000

# Supabase — leave blank to use the in-memory history store (dev). When set,
# completed matches are persisted to the `matches` table (see supabase/schema.sql).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
