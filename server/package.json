{
  "name": "@cardadda/server",
  "version": "0.1.0",
  "private": true,
  "description": "CardAdda real-time game server — Node + Socket.io, authoritative Callbreak state per room.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "DEV_AUTH=1 TRICK_HOLD_MS=80 vitest run"
  },
  "dependencies": {
    "@cardadda/engine": "*",
    "@cardadda/crazy8-engine": "*",
    "@cardadda/teenpatti-engine": "*",
    "@cardadda/thirtyone-engine": "*",
    "@cardadda/shared": "*",
    "@supabase/supabase-js": "^2.45.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "socket.io-client": "^4.7.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
