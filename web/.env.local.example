# Copy to .env.local.

# URL of the standalone Socket.io game server.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Supabase (public anon key — safe to expose). Required for real Google sign-in.
# Leave blank to run with the dev bypass only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only sign-in bypass. When 1, the login page offers a "play as test user"
# option (pick any username) so you can run the game without Google OAuth.
# Set to 0 (or unset) in production. Must match the server's DEV_AUTH.
NEXT_PUBLIC_DEV_AUTH=1
